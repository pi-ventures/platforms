// ─────────────────────────────────────────────────────────────────────────────
// IQEdge.ai — Cross-Vertical Intelligence Layer
//
// Pattern Recognition · Predictive Analytics · Cross-Vertical Insights
//
// Receives from ALL verticals:
//   TheCredit.exchange (finance) · TheEquinox.ai (trading) · YesBroker (real estate)
//   JustBuild.com (infra) · LegalOpinion (legal) · CuriousHat (education)
//   MedicinesDiscount (healthcare) · PI Foundation (CSR) · Sukoon @ Sukoon (living/PG)
//
// Pushes enriched insights to: KnowledgeHub.ai (Master Core)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════════════════════════════
// INGESTED STUDENT DATA (from CuriousHat)
// ═══════════════════════════════════════════════════════════════════════════════

model StudentSnapshot {
  id             String   @id @default(cuid())
  curioushatId   String   // student ID in CuriousHat
  schoolId       String
  name           String
  grade          String
  section        String
  board          String
  category       String?
  state          String
  pincode        String
  scores         Json     // full score array from CuriousHat
  attendance     Json     // {total, present, absent, percentage}
  profileCard    Json     // strength map, career recs, etc.
  entrancePrep   Json?    // entrance exam prep data
  ingestedAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt

  analytics      StudentAnalytics?
  predictions    Prediction[]

  @@unique([curioushatId])
  @@index([state, board])
  @@index([grade])
}

model StudentAnalytics {
  id                    String   @id @default(cuid())
  studentSnapshotId     String   @unique
  performanceTrend      Json     // [{month, avgPercent}]
  subjectStrength       Json     // {Math: 92, Physics: 87, ...}
  predictedBoardScore   Float?
  collegeReadinessScore Float?   // 0-100
  entranceExamReadiness Json?    // {JEE: 65, NEET: 40}
  careerFitScores       Json?    // [{career, fitPercent}]
  scholarshipEligibility Json?   // ["NSP", "State Merit"]
  peerRank              Json?    // {school, district, state}
  computedAt            DateTime @default(now())

  studentSnapshot StudentSnapshot @relation(fields: [studentSnapshotId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════════════════
// INGESTED SCHOOL DATA (from CuriousHat)
// ═══════════════════════════════════════════════════════════════════════════════

model SchoolSnapshot {
  id            String   @id @default(cuid())
  curioushatId  String   @unique
  name          String
  type          String   // PRIVATE, GOVERNMENT, AIDED, CENTRAL
  board         String
  udiseCode     String?
  city          String
  state         String
  pincode       String
  studentCount  Int
  teacherCount  Int
  metrics       Json     // {avgPassPercent, avgAttendance, boardExamPassRate, ...}
  govtSchemes   Json?    // scheme compliance data
  ingestedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  schoolAnalytics SchoolAnalytics?

  @@index([state, city])
  @@index([type])
}

model SchoolAnalytics {
  id                     String   @id @default(cuid())
  schoolSnapshotId       String   @unique
  passRate3yr            Json     // [75, 78, 82]
  avgScoreBySubject      Json     // {Math: 72, Science: 68, ...}
  attendanceTrend        Json     // [92, 91, 93, ...]
  teacherEffectiveness   Json?    // {teacherName: score}
  infrastructureScore    Float?   // 0-100
  improvementIndex       Float?   // year-over-year improvement
  districtRank           Int?
  stateRank              Int?
  computedAt             DateTime @default(now())

  schoolSnapshot SchoolSnapshot @relation(fields: [schoolSnapshotId], references: [id], onDelete: Cascade)
}

// ═══════════════════════════════════════════════════════════════════════════════
// AI PREDICTIONS
// ═══════════════════════════════════════════════════════════════════════════════

model Prediction {
  id                String   @id @default(cuid())
  studentSnapshotId String
  type              String   // BOARD_SCORE, CAREER_FIT, COLLEGE_MATCH, ENTRANCE_SCORE, DROPOUT_RISK
  input             Json     // features used for prediction
  output            Json     // prediction results
  confidence        Float    // 0-1
  model             String   // model version/name
  computedAt        DateTime @default(now())

  studentSnapshot StudentSnapshot @relation(fields: [studentSnapshotId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([studentSnapshotId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// AGGREGATE ANALYTICS (district/state/national level)
// ═══════════════════════════════════════════════════════════════════════════════

model AggregateReport {
  id            String   @id @default(cuid())
  scope         String   // district, state, national
  scopeId       String   // district name, state code, 'IN'
  academicYear  String
  board         String?
  totalStudents Int
  totalSchools  Int
  avgPassRate   Float
  genderGap     Float?   // boys avg - girls avg
  dropoutRate   Float?
  topSchools    Json?    // [{name, score}]
  bottomSchools Json?    // [{name, score}]
  subjectWise   Json?    // {Math: 68, Science: 72, ...}
  govtVsPrivate Json?   // {govtAvg, privateAvg}
  computedAt    DateTime @default(now())

  @@unique([scope, scopeId, academicYear])
  @@index([scope])
}

// ═══════════════════════════════════════════════════════════════════════════════
// LEADERBOARDS
// ═══════════════════════════════════════════════════════════════════════════════

model Leaderboard {
  id            String   @id @default(cuid())
  type          String   // school, district, state
  scope         String   // state_code, 'national'
  academicYear  String
  entries       Json     // [{rank, name, score, improvement}]
  computedAt    DateTime @default(now())

  @@unique([type, scope, academicYear])
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYNC LOGS
// ═══════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// INGESTED LIVING DATA (from Sukoon @ Sukoon)
// ═══════════════════════════════════════════════════════════════════════════════

model PropertySnapshot {
  id            String   @id @default(cuid())
  sukoonId      String   @unique // property ID in Sukoon
  name          String
  type          String   // PG, HOSTEL, COLIVING, FLAT_SHARE
  gender        String   // MALE, FEMALE, UNISEX
  city          String
  state         String
  pincode       String
  locality      String?
  totalBeds     Int
  occupiedBeds  Int      @default(0)
  avgRent       Float?
  amenities     Json     // {wifi, ac, parking, laundry, mess, ...}
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  has365Store   Boolean  @default(false)
  storeFormat   String?  // VENDING_MACHINE, KIOSK, STORE, etc.
  ingestedAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  analytics     PropertyAnalytics?

  @@index([city, state])
  @@index([type, gender])
}

model PropertyAnalytics {
  id                    String   @id @default(cuid())
  propertySnapshotId    String   @unique
  occupancyRate         Float?   // 0-100
  occupancyTrend        Json?    // [{month, rate}]
  avgStayDuration       Float?   // months
  churnRate             Float?   // monthly tenant turnover %
  revenueTrend          Json?    // [{month, rent, store365, meals}]
  mealAdoptionRate      Float?   // % tenants with tiffin subscription
  store365Revenue       Float?   // monthly 365 Days revenue
  topSellingProducts    Json?    // [{product, quantity, revenue}]
  demandScore           Float?   // 0-100, locality demand
  priceCompetitiveness  Float?   // vs locality average
  computedAt            DateTime @default(now())

  propertySnapshot PropertySnapshot @relation(fields: [propertySnapshotId], references: [id], onDelete: Cascade)
}

model CityLivingSnapshot {
  id              String   @id @default(cuid())
  city            String
  state           String
  totalProperties Int      @default(0)
  totalBeds       Int      @default(0)
  occupiedBeds    Int      @default(0)
  avgRent         Float?
  avgOccupancy    Float?
  maleProperties  Int      @default(0)
  femaleProperties Int     @default(0)
  pgCount         Int      @default(0)
  hostelCount     Int      @default(0)
  colivingCount   Int      @default(0)
  store365Count   Int      @default(0)
  totalMealSubs   Int      @default(0)
  monthlyRevenue  Json?    // {rent, meals, store365, total}
  topLocalities   Json?    // [{name, properties, avgRent, occupancy}]
  computedAt      DateTime @default(now())

  @@unique([city, state])
  @@index([state])
}

// ═══════════════════════════════════════════════════════════════════════════════
// CROSS-VERTICAL INTELLIGENCE
// ═══════════════════════════════════════════════════════════════════════════════

model VerticalDataPoint {
  id          String   @id @default(cuid())
  vertical    String   // thecredit, theequinox, yesbroker, justbuild, legalopinion, curioushat, medicines, pifoundation, sukoon
  entityId    String   // ID in source vertical
  entityType  String   // company, individual, school, property, tender, case
  data        Json     // raw data snapshot
  features    Json?    // extracted ML features
  ingestedAt  DateTime @default(now())

  @@unique([vertical, entityId])
  @@index([vertical])
  @@index([entityType])
}

model PatternDetection {
  id              String   @id @default(cuid())
  patternType     String   // cross_sell, risk_correlation, market_signal, anomaly, opportunity
  verticals       String[] // which verticals involved
  description     String
  entities        Json     // [{vertical, entityId, role}]
  confidence      Float    // 0-1
  impact          String   // low, medium, high, critical
  actionable      Boolean  @default(true)
  detectedAt      DateTime @default(now())

  @@index([patternType])
  @@index([impact])
}

model CrossVerticalInsight {
  id              String   @id @default(cuid())
  sourceVerticals String[] // e.g. ["yesbroker", "thecredit"]
  insightType     String   // risk_alert, opportunity, trend, correlation
  title           String
  description     String
  dataPoints      Json     // supporting evidence
  recommendation  String?  // AI-suggested action
  confidence      Float
  targetVerticals String[] // who should see this
  isActioned      Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([insightType])
}

model PredictiveModel {
  id              String   @id @default(cuid())
  name            String   // company_default_risk, student_board_score, property_price, tender_win_prob
  vertical        String   // primary vertical or 'cross'
  version         String
  accuracy        Float?
  precision       Float?
  recall          Float?
  f1Score         Float?
  featureCount    Int?
  trainingRecords Int?
  lastTrainedAt   DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  predictions     PredictiveResult[]

  @@unique([name, version])
}

model PredictiveResult {
  id              String   @id @default(cuid())
  modelId         String
  entityId        String   // what was predicted on
  entityType      String
  vertical        String
  prediction      Json     // model output
  confidence      Float
  computedAt      DateTime @default(now())

  model           PredictiveModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([vertical, entityType])
  @@index([modelId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// SYNC LOGS
// ═══════════════════════════════════════════════════════════════════════════════

model IngestLog {
  id           String    @id @default(cuid())
  source       String    // all verticals
  eventType    String
  recordCount  Int       @default(1)
  status       String    @default("received")
  error        String?
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?
}

model OutgestLog {
  id           String    @id @default(cuid())
  target       String    // knowledgehub
  eventType    String
  payload      Json
  status       String    @default("pending")
  responseCode Int?
  error        String?
  createdAt    DateTime  @default(now())
  sentAt       DateTime?
}

// ═══════════════════════════════════════════════════════════════════════════════
// WHATSAPP AI AGENT
// ═══════════════════════════════════════════════════════════════════════════════

// A WhatsApp Business Account connected to IQEdge
model WhatsAppAccount {
  id                String   @id @default(cuid())
  phoneNumberId     String   @unique // Meta WhatsApp Business phone number ID
  displayPhone      String   // e.g. +91-9876543210
  businessName      String
  wabaId            String?  // WhatsApp Business Account ID
  accessToken       String   // Meta Cloud API token (encrypted in production)
  webhookVerifyToken String  // token for webhook verification
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  conversations     WhatsAppConversation[]
  agents            WhatsAppAgent[]
}

// AI Agent definitions — each handles a specific domain
model WhatsAppAgent {
  id              String   @id @default(cuid())
  accountId       String
  name            String   // e.g. "Lead Qualifier", "Store Compliance", "Support"
  description     String?
  systemPrompt    String   // LLM system prompt for this agent's behavior
  triggerKeywords String[] // keywords that route a message to this agent
  isDefault       Boolean  @default(false) // fallback agent when no keyword match
  isActive        Boolean  @default(true)
  config          Json?    // agent-specific settings (checklist items, scoring rubrics, etc.)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account         WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages        WhatsAppMessage[]

  @@index([accountId])
}

// A conversation thread with a single WhatsApp user
model WhatsAppConversation {
  id              String   @id @default(cuid())
  accountId       String
  waUserId        String   // WhatsApp user's phone number (e.g. 919876543210)
  waUserName      String?  // profile name from WhatsApp
  contactId       String?  // linked KnowledgeHub contact ID (once matched/created)
  companyId       String?  // linked company ID (once matched)
  status          String   @default("active") // active, archived, blocked
  lastMessageAt   DateTime?
  unreadCount     Int      @default(0)
  tags            String[] // user-assigned tags
  assignedTo      String?  // team member handling this conversation
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  account         WhatsAppAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages        WhatsAppMessage[]

  @@unique([accountId, waUserId])
  @@index([contactId])
  @@index([status])
  @@index([lastMessageAt])
}

// Individual messages in a conversation
model WhatsAppMessage {
  id              String   @id @default(cuid())
  conversationId  String
  agentId         String?  // which AI agent handled this (null = human/inbound)
  waMessageId     String?  @unique // WhatsApp's message ID
  direction       String   // inbound, outbound
  type            String   // text, image, document, audio, video, location, contact, template
  body            String?  // text content
  mediaUrl        String?  // URL for media messages
  mediaType       String?  // MIME type
  latitude        Float?   // for location messages
  longitude       Float?
  templateName    String?  // for outbound template messages
  status          String   @default("sent") // sent, delivered, read, failed
  aiIntent        String?  // detected intent (lead, complaint, query, compliance, etc.)
  aiConfidence    Float?   // intent detection confidence
  aiResponse      String?  // AI-generated response (before sending)
  metadata        Json?    // any extra data (button replies, list selections, etc.)
  createdAt       DateTime @default(now())

  conversation    WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent           WhatsAppAgent? @relation(fields: [agentId], references: [id])

  @@index([conversationId, createdAt])
  @@index([direction])
  @@index([aiIntent])
}

// Contact enrichment queue — tracks enrichment status per contact
model EnrichmentTask {
  id              String   @id @default(cuid())
  contactId       String   // KnowledgeHub contact ID
  source          String   // whatsapp, gbp, manual, bulk
  phone           String?
  email           String?
  name            String?
  status          String   @default("pending") // pending, processing, completed, failed
  enrichments     Json?    // results: {google: {...}, whatsapp: {...}, linkedin: {...}, gbp: {...}}
  matchedRecords  Json?    // IDs of matched records across tables
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@index([status])
  @@index([phone])
  @@index([email])
}

// WhatsApp message templates (pre-approved by Meta)
model WhatsAppTemplate {
  id              String   @id @default(cuid())
  accountId       String
  name            String   // template name registered with Meta
  language        String   @default("en")
  category        String   // MARKETING, UTILITY, AUTHENTICATION
  headerType      String?  // TEXT, IMAGE, VIDEO, DOCUMENT
  headerContent   String?
  bodyText        String   // template body with {{1}}, {{2}} placeholders
  footerText      String?
  buttons         Json?    // [{type: "QUICK_REPLY"|"URL", text, url?}]
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime @default(now())

  @@unique([accountId, name, language])
}
